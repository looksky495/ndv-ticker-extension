{
  "name": "ndv-ticker-extension",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:ts": "tsc && vite build",
    "build:wasm": "wasm-pack build src/wasm/rust --target web --out-name eewcalc --release",
    "build": "npm run build:wasm && npm run build:ts",
    "test:qt-ajv": "node --test --import tsx tests/qt/validate-*.test.ts"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.42",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.6.2",
    "ajv": "^8.20.0",
    "ts-json-schema-generator": "^2.9.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-static-copy": "^4.1.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "dependencies": {
    "@zip.js/zip.js": "^2.8.26"
  }
}
